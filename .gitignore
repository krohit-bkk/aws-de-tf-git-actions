# Terraform state files
*.tfstate
*.tfstate.backup

# Terraform working directory
.terraform/
.terraform.lock.hcl
.terraform.tfstate.lock.info

# Variable values (contains sensitive info)
terraform.tfvars

# Lambda zip packages (generated by Terraform automatically)
modules/lambda/functions/*.zip

# Python cache
__pycache__/
*.pyc
*.pyo

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/
*.swp
*.swo

# Notes (personal, not for repo)
notes.txt